# Environment Configuration Template
# Copy this to .env and fill in your actual values
# NEVER commit .env to version control!

# ===================================
# SERVER CONFIGURATION
# ===================================
PORT=5000
NODE_ENV=development
HOST=0.0.0.0

# ===================================
# DATABASE CONFIGURATION
# ===================================
# For production, use MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/skillExchange?retryWrites=true&w=majority
# For local development:
MONGODB_URI=mongodb://localhost:27017/SkillExchange

# ===================================
# JWT CONFIGURATION
# ===================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_STRING_32_CHARS_OR_MORE
JWT_EXPIRE=30d
# Admin JWT secret — must be set HERE (NOT in client/admin/.env.admin which is publicly served)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ADMIN_JWT_SECRET=CHANGE_THIS_TO_A_DIFFERENT_RANDOM_STRING
# Admin session secret — must be set HERE (NOT in client/admin/.env.admin which is publicly served)
ADMIN_SESSION_SECRET=CHANGE_THIS_TO_YET_ANOTHER_RANDOM_STRING

# ===================================
# CLIENT CONFIGURATION
# ===================================
CLIENT_URL=http://localhost:5000
CORS_ORIGINS=http://localhost:5000,http://localhost:3000

# ===================================
# EMAIL CONFIGURATION (SendGrid)
# ===================================
# Get API Key from: https://app.sendgrid.com/settings/api_keys
# IMPORTANT: FROM_EMAIL must be a verified sender in your SendGrid account.
# Verify at: https://app.sendgrid.com/settings/sender_auth
# Use Single Sender Verification (easiest) or full Domain Authentication.
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=you@yourdomain.com
FROM_NAME=SkillExchange Platform
SUPPORT_EMAIL=support@yourdomain.com
EMAIL_ENABLED=true

# ===================================
# SMS CONFIGURATION (Twilio - Optional)
# ===================================
# Password reset and 2FA via SMS support
# Get credentials from: https://www.twilio.com/console
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

# ===================================
# 2FA & SECURITY FEATURES
# ===================================
# Enable Two-Factor Authentication for password reset
ENABLE_2FA_RESET=true
# Enable Email Verification before password reset
ENABLE_EMAIL_VERIFICATION=true
# Enable SMS password reset support
ENABLE_SMS_RESET=true

# ===================================
# SECURITY CONFIGURATION
# ===================================
# Rate limiting (requests per window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Enable/disable security features
HELMET_ENABLED=true
CSP_ENABLED=false

# ===================================
# CLOUDINARY CONFIGURATION
# ===================================
# Get credentials from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ===================================
# FILE UPLOAD CONFIGURATION
# ===================================
MAX_FILE_UPLOAD=10485760
FILE_UPLOAD_PATH=./uploads
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf

# ===================================
# LOGGING CONFIGURATION
# ===================================
LOG_LEVEL=debug
ENABLE_LOGGING=true

# ===================================
# REDIS CONFIGURATION (Production)
# ===================================
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ===================================
# MONITORING & ERROR TRACKING
# ===================================
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ===================================
# EXTERNAL SERVICES
# ===================================
# Google OAuth (Optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ===================================
# SSL/TLS CONFIGURATION (Production)
# ===================================
# SSL_KEY_PATH=/path/to/your/private.key
# SSL_CERT_PATH=/path/to/your/certificate.crt

# ===================================
# DATABASE BACKUP CONFIGURATION
# ===================================
# BACKUP_ENABLED=true
# BACKUP_SCHEDULE=0 2 * * *
# BACKUP_RETENTION_DAYS=30
